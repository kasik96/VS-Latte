{
	"name": "latte",
	"displayName": "Nette Latte + Neon",
	"description": "Nette Latte + Neon support for VS Code",
	"version": "0.18.2",
	"publisher": "Kasik96",
	"engines": {
		"vscode": "^0.10.1"
	},
	"icon": "icon.png",
	"categories": [
		"Languages"
	],
	"galleryBanner": {
		"color": "#3484D3",
		"theme": "light"
	},
	"bugs": {
		"url": "https://github.com/kasik96/VS-Latte/issues",
		"email": "mail@kasemartin.cz"
	},
	"homepage": "https://github.com/kasik96/VS-Latte",
	"repository": {
		"type": "git",
		"url": "https://github.com/kasik96/VS-Latte"
	},
	"scripts": {
		"test:grammar:latte": "vscode-tmgrammar-test -g syntaxes/latte.tmLanguage \"tests/latte/*.test.latte\"",
		"test:grammar:neon": "vscode-tmgrammar-test -g syntaxes/neon.tmLanguage \"tests/neon/*.test.neon\"",
		"test:grammar": "npm run test:grammar:latte && npm run test:grammar:neon",
		"test:snippets": "node tests/validate-snippets.mjs",
		"test": "npm run test:grammar && npm run test:snippets",
		"prepare-hooks": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
	},
	"devDependencies": {
		"vscode-tmgrammar-test": "^0.1.3"
	},
	"contributes": {
		"languages": [
			{
				"id": "neon",
				"aliases": [
					"Neon",
					"neon"
				],
				"extensions": [
					".neon"
				],
				"configuration": "./neon.configuration.json"
			},
			{
				"id": "latte",
				"aliases": [
					"Latte",
					"latte"
				],
				"extensions": [
					".latte"
				],
				"configuration": "./latte.configuration.json"
			}
		],
		"grammars": [
			{
				"language": "neon",
				"scopeName": "source.neon",
				"path": "./syntaxes/neon.tmLanguage"
			},
			{
				"language": "latte",
				"scopeName": "source.latte",
				"path": "./syntaxes/latte.tmLanguage"
			},
			{
				"scopeName": "source.latte-injection",
				"path": "./syntaxes/latte-html-injection.tmLanguage.json",
				"injectTo": ["source.latte"]
			}
		],
		"snippets": [
			{
				"language": "latte",
				"path": "./snippets/snippets.json"
			}
		],
		"configurationDefaults": {
			"emmet.includeLanguages": {
				"latte": "html"
			}
		}
	}
}
